@model IEnumerable<ServiciosTecnicos.Models.ServiceRequest>

@{
    ViewData["Title"] = "Solicitudes";
}

<style>
    .tad-info-card {
        border-radius: 12px;
        border: 2px solid #667eea;
        background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
        padding: 15px;
        margin-bottom: 20px;
    }
</style>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-list-task"></i> Solicitudes</h1>
        <div>
            <span class="badge bg-primary fs-6">@ViewBag.TotalRequests Total</span>
            <span class="badge bg-warning fs-6">@ViewBag.PendingInQueue En Cola</span>
        </div>
    </div>

    <div class="mb-3 d-flex gap-2">
        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Nueva solicitud
        </a>
        <a asp-action="AttendNext" class="btn btn-danger">
            <i class="bi bi-play-circle"></i> Atender siguiente
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Info"] != null)
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            @TempData["Info"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Cliente</th>
                <th>Servicio</th>
                <th>Descripción</th>
                <th>Fecha</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Client.User.FirstName @item.Client.User.LastName</td>
                    <td>@item.Category.CategoryName</td>
                    <td>@item.Description</td>
                    <td>@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>
                        @if (item.RequestStatus == "pending")
                        {
                            <span class="badge bg-warning text-dark">Pendiente</span>
                        }
                        else if (item.RequestStatus == "assigned")
                        {
                            <span class="badge bg-info">Asignado</span>
                        }
                        else if (item.RequestStatus == "in_progress")
                        {
                            <span class="badge bg-primary">En Progreso</span>
                        }
                        else if (item.RequestStatus == "completed")
                        {
                            <span class="badge bg-success">Completado</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">@item.RequestStatus</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.RequestId" class="btn btn-sm btn-info">Detalles</a>
                        <a asp-action="Edit" asp-route-id="@item.RequestId" class="btn btn-sm btn-warning">Editar</a>
                        <a asp-action="Delete" asp-route-id="@item.RequestId" class="btn btn-sm btn-danger">Eliminar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            No hay solicitudes registradas.
        </div>
    }

    <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Regresar</a>
</div>