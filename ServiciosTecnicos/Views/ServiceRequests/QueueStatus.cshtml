@model ServiceRequest[]

@{
    ViewData["Title"] = "Estado de Servicios Tecnicos";
}

<style>
    .queue-shell {
        border-radius: 12px;
        box-shadow: 0 4px 14px rgba(0, 0, 0, 0.08);
        border: 1px solid #d9e5ee;
        overflow: hidden;
        margin-bottom: 20px;
        background: #fff;
    }

    .queue-header {
        background: #087ca7;
        color: white;
        padding: 28px 32px;
    }

    .queue-summary {
        border: 1px solid #b8dce8;
        background: #e8f6fb;
        color: #084c61;
        border-radius: 8px;
        padding: 18px 20px;
    }

    .metric-card {
        border: 1px solid #cfe2ef;
        border-radius: 8px;
        background: #1b6ec2;
        color: white;
        min-height: 120px;
    }

        .metric-card.secondary {
            background: #087ca7;
        }

    .queue-position {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        background: #087ca7;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        font-weight: bold;
        color: white;
    }

    .queue-item {
        border: 1px solid #d9e5ee;
        border-radius: 8px;
    }

    .fifo-arrow {
        font-size: 32px;
        color: #087ca7;
        text-align: center;
        margin: 14px 0;
    }
</style>

<div class="container py-4">
    <div class="queue-shell">
        <div class="queue-header">
            <h2 class="mb-1">Estado de Servicios Tecnicos</h2>
            <p class="mb-0 opacity-75">Solicitudes pendientes de atencion</p>
        </div>

        <div class="p-4">
            <div class="queue-summary mb-4">
                <h5 class="mb-2">Atencion por orden de llegada</h5>
                <p class="mb-0">
                    Las solicitudes pendientes se atienden en el orden en que fueron creadas.
                </p>
            </div>

            <div class="row mb-4">
                <div class="col-md-6 mb-3 mb-md-0">
                    <div class="metric-card d-flex flex-column align-items-center justify-content-center text-center">
                        <h3 class="display-4 mb-2">@ViewBag.QueueCount</h3>
                        <p class="mb-0">Solicitudes en cola</p>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="metric-card secondary d-flex align-items-center justify-content-center text-center">
                        <p class="mb-0 fs-5 fw-semibold">Servicios tecnicos</p>
                    </div>
                </div>
            </div>

            @if (Model.Length > 0)
            {
                <h4 class="mb-4">Orden de Atencion</h4>

                @for (int i = 0; i < Model.Length; i++)
                {
                    var request = Model[i];

                    <div class="queue-item mb-3 p-3">
                        <div class="row align-items-center g-3">
                            <div class="col-md-1">
                                <div class="queue-position">@(i + 1)</div>
                            </div>
                            <div class="col-md-7">
                                <h5 class="mb-1">
                                    @if (i == 0)
                                    {
                                        <span class="badge bg-danger">SIGUIENTE</span>
                                    }
                                    #@request.RequestId - @request.Title
                                </h5>
                                <p class="mb-0 text-muted">
                                    @request.Client?.User?.FirstName @request.Client?.User?.LastName |
                                    @request.Category?.CategoryName |
                                    @request.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                </p>
                            </div>
                            <div class="col-md-4 text-md-end">
                                <a asp-action="Details" asp-route-id="@request.RequestId" class="btn btn-primary">
                                    Ver detalles
                                </a>
                            </div>
                        </div>
                    </div>

                    @if (i < Model.Length - 1)
                    {
                        <div class="fifo-arrow">?</div>
                    }
                }

                <div class="text-center mt-4">
                    <form asp-action="AttendNext" method="get">
                        <button type="submit" class="btn btn-success btn-lg">
                            Atender siguiente
                        </button>
                    </form>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <h4 class="mt-3 text-muted">Cola vacia</h4>
                    <p class="text-muted">No hay solicitudes pendientes en la cola de atencion.</p>
                </div>
            }

            <div class="mt-4 d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-secondary">Volver a lista</a>
                <a asp-controller="Historial" asp-action="Index" class="btn btn-primary">Historial</a>
            </div>
        </div>
    </div>
</div>