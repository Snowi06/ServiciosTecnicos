@model ServiciosTecnicos.Models.ServiceRequest

@{
    ViewData["Title"] = "Nueva Solicitud";
}

<h2>Nueva Solicitud</h2>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    
    @if (ViewBag.CurrentClientId != null)
    {
        <div class="mb-3">
            <label class="form-label">Cliente</label>
            <input type="text" class="form-control" value="@ViewBag.CurrentClientName" readonly />
            <input type="hidden" name="ClientId" value="@ViewBag.CurrentClientId" />
        </div>
    }
    else
    {
        <div class="mb-3">
            <label for="ClientId" class="form-label">Cliente</label>
            <select name="ClientId" id="ClientId" class="form-select" required>
                <option value="">-- Seleccione un cliente --</option>
                @foreach (var item in (SelectList)ViewBag.Clients)
                {
                    <option value="@item.Value">@item.Text</option>
                }
            </select>
        </div>
    }


    <div class="mb-3">
        <label for="CategoryId" class="form-label">CategorÝa de Servicio</label>
        <select name="CategoryId" id="CategoryId" class="form-select" required>
            <option value="">-- Seleccione una categorÝa --</option>
            @foreach (var item in (SelectList)ViewBag.Categories)
            {
                <option value="@item.Value">@item.Text</option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label for="Title" class="form-label">TÝtulo</label>
        <input type="text" name="Title" id="Title" class="form-control" required />
    </div>

    <div class="mb-3">
        <label for="Description" class="form-label">Descripciˇn</label>
        <textarea name="Description" id="Description" class="form-control" rows="4" required></textarea>
    </div>

    <div class="mb-3">
        <label for="Address" class="form-label">Direcciˇn</label>
        <input type="text" name="Address" id="Address" class="form-control" required />
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-success">Crear Solicitud</button>
        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
    </div>
</form>     