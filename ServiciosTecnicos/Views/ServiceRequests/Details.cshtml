@model ServiciosTecnicos.Models.ServiceRequest

@{
    ViewData["Title"] = "Detalles de Solicitud";

    var isPending = Model.RequestStatus == "pendiente" || Model.RequestStatus == "pending";
    var isAssigned = Model.RequestStatus == "asignado" || Model.RequestStatus == "assigned" || Model.RequestStatus == "in_progress";
    var isFinished = Model.RequestStatus == "finalizado" || Model.RequestStatus == "completed";
}

<h2>Detalles de Solicitud</h2>

<div class="row">
    <div class="col-md-8">
        <dl class="row">
            <dt class="col-sm-4">ID Solicitud</dt>
            <dd class="col-sm-8">@Model.RequestId</dd>

            <dt class="col-sm-4">Cliente</dt>
            <dd class="col-sm-8">@Model.Client?.User?.FirstName @Model.Client?.User?.LastName</dd>

            <dt class="col-sm-4">Email</dt>
            <dd class="col-sm-8">@Model.Client?.User?.Email</dd>

            <dt class="col-sm-4">Telťfono</dt>
            <dd class="col-sm-8">@Model.Client?.User?.Phone</dd>

            <dt class="col-sm-4">CategorŪa</dt>
            <dd class="col-sm-8">@Model.Category?.CategoryName</dd>

            <dt class="col-sm-4">TŪtulo</dt>
            <dd class="col-sm-8">@Model.Title</dd>

            <dt class="col-sm-4">Descripciůn</dt>
            <dd class="col-sm-8">@Model.Description</dd>

            <dt class="col-sm-4">Direcciůn</dt>
            <dd class="col-sm-8">@Model.Address</dd>

            <dt class="col-sm-4">Estado</dt>
            <dd class="col-sm-8">
                @if (isPending)
                {
                    <span class="badge bg-warning text-dark">Pendiente</span>
                }
                else if (isAssigned)
                {
                    <span class="badge bg-info">Asignado</span>
                }
                else if (isFinished)
                {
                    <span class="badge bg-success">Finalizado</span>
                }
                else
                {
                    <span class="badge bg-secondary">@Model.RequestStatus</span>
                }

            </dd>

            <dt class="col-sm-4">Fecha de Creaciůn</dt>
            <dd class="col-sm-8">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</dd>

            @if (Model.RequestAssignment != null)
            {
                <dt class="col-sm-4">Tťcnico Asignado</dt>
                <dd class="col-sm-8">
                    @Model.RequestAssignment.Technician?.User?.FirstName @Model.RequestAssignment.Technician?.User?.LastName
                    <br />
                    <small class="text-muted">Asignado: @Model.RequestAssignment.AssignedAt.ToString("dd/MM/yyyy HH:mm")</small>
                </dd>
            }
        </dl>

        @* Secciůn para asignar tťcnico si estŠ pendiente *@
        @if (isPending && Model.RequestAssignment == null)
        {
            <div class="card mt-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Asignar Tťcnico</h5>
                </div>
                <div class="card-body">
                    <form asp-action="AssignTechnician" method="post">
                        <input type="hidden" name="requestId" value="@Model.RequestId" />
                        
                        <div class="mb-3">
                            <label for="technicianId" class="form-label">Seleccione un Tťcnico Disponible</label>
                            <select name="technicianId" id="technicianId" class="form-select" required>
                                <option value="">-- Seleccione un tťcnico --</option>
                                @if (ViewBag.AvailableTechnicians != null)
                                {
                                    @foreach (var tech in (SelectList)ViewBag.AvailableTechnicians)
                                    {
                                        <option value="@tech.Value">@tech.Text</option>
                                    }
                                }
                            </select>
                        </div>

                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-person-check"></i> Asignar Tťcnico
                        </button>
                    </form>
                </div>
            </div>
        }

        @* Botůn para iniciar servicio si estŠ asignado *@
        @if (isAssigned && !isFinished)
        {
            <div class="alert alert-info mt-4">
                <h5>Solicitud Asignada</h5>
                <p>Esta solicitud ya tiene tťcnico asignado. Puedes iniciar el servicio o marcarla como finalizada.</p>

                @if (Model.Service == null)
                {
                    <form asp-action="StartService" method="post" class="d-inline">
                        <input type="hidden" name="requestId" value="@Model.RequestId" />
                        <button type="submit" class="btn btn-primary">
                            Iniciar Servicio
                        </button>
                    </form>
                }

                <form asp-action="FinishService" method="post" class="d-inline">
                    <input type="hidden" name="requestId" value="@Model.RequestId" />
                    <button type="submit" class="btn btn-success">
                        Finalizar Solicitud
                    </button>
                </form>
            </div>
        }


        <div class="mt-4">
            <a asp-action="Edit" asp-route-id="@Model.RequestId" class="btn btn-warning">Editar</a>
            <a asp-action="Index" class="btn btn-secondary">Volver a la lista</a>
        </div>
    </div>
</div>