@model ServiciosTecnicos.Models.ServiceRequest

@{
    ViewData["Title"] = "Editar Solicitud";
    var isAdmin = Context.Session.GetString("Role") == "admin";
}

<h2>Editar Solicitud</h2>

<form asp-action="Edit" asp-route-id="@Model.RequestId" method="post">
    @Html.AntiForgeryToken()

    <input type="hidden" name="RequestId" value="@Model.RequestId" />
    <input type="hidden" name="CreatedAt" value="@Model.CreatedAt.ToString("o")" />

    @if (isAdmin)
    {
        <div class="mb-3">
            <label for="ClientId" class="form-label">Cliente</label>
            <select name="ClientId" id="ClientId" class="form-select" required>
                @foreach (var item in (SelectList)ViewBag.Clients)
                {
                    <option value="@item.Value" selected="@(item.Selected ? "selected" : null)">@item.Text</option>
                }
            </select>
        </div>
    }
    else
    {
        <input type="hidden" name="ClientId" value="@Model.ClientId" />

        <div class="mb-3">
            <label class="form-label">Cliente</label>
            <input type="text" class="form-control" value="@ViewBag.CurrentClientName" readonly />
        </div>
    }

    <div class="mb-3">
        <label for="CategoryId" class="form-label">Categoría de Servicio</label>
        <select name="CategoryId" id="CategoryId" class="form-select" required>
            @foreach (var item in (SelectList)ViewBag.Categories)
            {
                <option value="@item.Value" selected="@(item.Selected ? "selected" : null)">@item.Text</option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label for="Title" class="form-label">Título</label>
        <input type="text" name="Title" id="Title" class="form-control" value="@Model.Title" required />
    </div>

    <div class="mb-3">
        <label for="Description" class="form-label">Descripción</label>
        <textarea name="Description" id="Description" class="form-control" rows="4" required>@Model.Description</textarea>
    </div>

    <div class="mb-3">
        <label for="Address" class="form-label">Dirección</label>
        <input type="text" name="Address" id="Address" class="form-control" value="@Model.Address" required />
    </div>

    @if (isAdmin)
    {
        <div class="mb-3">
            <label for="RequestStatus" class="form-label">Estado</label>
            <select name="RequestStatus" id="RequestStatus" class="form-select" required>
                <option value="pendiente" selected="@(Model.RequestStatus == "pendiente" || Model.RequestStatus == "pending" ? "selected" : null)">Pendiente</option>
                <option value="asignado" selected="@(Model.RequestStatus == "asignado" || Model.RequestStatus == "assigned" || Model.RequestStatus == "in_progress" ? "selected" : null)">Asignado</option>
                <option value="finalizado" selected="@(Model.RequestStatus == "finalizado" || Model.RequestStatus == "completed" ? "selected" : null)">Finalizado</option>
            </select>
        </div>
    }
    else
    {
        <input type="hidden" name="RequestStatus" value="@Model.RequestStatus" />

        <div class="mb-3">
            <label class="form-label">Estado</label>
            <input type="text" class="form-control" value="@Model.RequestStatus" readonly />
        </div>
    }

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Guardar Cambios</button>
        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
    </div>
</form>
