@model LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<div class="login-page">

    <div class="login-panel">

        <div class="text-center mb-4">
            <div class="login-logo">
                ST
            </div>

            <h2 class="fw-bold mt-3 mb-1">
                Servicios Técnicos
            </h2>

            <p class="text-muted mb-0">
                Accede con tus credenciales
            </p>
        </div>

        <div class="alert alert-info">
            Si ya tienes una cuenta, utiliza tu correo y contraseña.
            Si no tienes cuenta, puedes registrarte como cliente.
        </div>

        <form asp-controller="Login" asp-action="Index" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label">Correo</label>
                <input asp-for="Email" class="form-control form-control-lg">
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label">Contraseña</label>
                <input asp-for="Password" type="password" class="form-control form-control-lg">
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-primary btn-lg w-100">
                ACCEDER
            </button>

            <div class="text-center mt-4">
                <a asp-controller="Login" asp-action="Register" class="fw-semibold">
                    Crear cuenta nueva
                </a>
            </div>

            <div class="text-center mt-3">
                <a asp-controller="Home" asp-action="Index" class="btn btn-warning px-4">
                    Regresar al Inicio
                </a>
            </div>
        </form>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
