@model ServiciosTecnicos.Models.Solicitud

@{
    ViewData["Title"] = "Nueva solicitud";
}

<h1>Nueva solicitud</h1>

<form method="post">

    <div>
        <label>Nombre del cliente</label>
        <input asp-for="NombreCliente" class="form-control" />
    </div>

    <br />

    <div>
        <label>Tipo de servicio</label>
        <input asp-for="TipoServicio" class="form-control" />
    </div>

    <br />

    <div>
        <label>Descripción</label>
<textarea asp-for="Descripcion" class="form-control"></textarea>
    </div>

    <br />

    <button class="btn btn-primary">
        Registrar solicitud
    </button>

    <a href="/Solicitudes" class="btn btn-secondary">
        Volver
    </a>

</form>
