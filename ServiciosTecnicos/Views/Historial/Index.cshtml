@model ServiciosTecnicos.Models.Service[]

@{
    ViewData["Title"] = "Historial";
}

<div class="container mt-5">
    <h2 class="fw-bold mb-3">Historial de Servicios Atendidos</h2>

    @if (Model.Length == 0)
    {
        <div class="alert alert-info">Aún no hay servicios atendidos.</div>
    }
    else
    {
        <table class="table table-striped table-hover align-middle">
            <thead>
                <tr>
                    <th>Solicitud</th>
                    <th>Cliente</th>
                    <th>Categoría</th>
                    <th>Técnico</th>
                    <th>Inicio</th>
                    <th>Finalización</th>
                    <th>Estado</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var service in Model)
                {
                    <tr>
                        <td>#@service.RequestId - @service.Request.Title</td>
                        <td>@service.Request.Client.User.FirstName @service.Request.Client.User.LastName</td>
                        <td>@service.Request.Category.CategoryName</td>
                        <td>@service.Technician.User.FirstName @service.Technician.User.LastName</td>
                        <td>@(service.StartDate?.ToString("dd/MM/yyyy HH:mm") ?? "Sin inicio")</td>
                        <td>@(service.EndDate?.ToString("dd/MM/yyyy HH:mm") ?? "Sin fecha")</td>
                        <td><span class="badge bg-success">Finalizado</span></td>

                        <td>
                        <a asp-controller="Calificaciones"
                           asp-action="Create"
                           asp-route-serviceId="@service.ServiceId"
                           class="btn btn-sm btn-primary">
                           Calificar
                        </a>
            </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Regresar</a>
</div>
